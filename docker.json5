{
  "packageRules": [
    // Docker - Patch and Minor
    {
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["docker"],
      "groupName": "Docker (non-major)",
      "commitMessagePrefix": "chore(docker):",
      "commitMessageExtra": "({{#each upgrades}}{{{depName}}} {{{newVersion}}}{{#unless @last}}, {{/unless}}{{/each}})",
      "automerge": false
    },
    // Docker - Major
    {
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["major"],
      "labels": ["docker", "breaking"],
      "groupName": "Docker (major)",
      "commitMessagePrefix": "chore(docker)!:",
      "commitMessageExtra": "({{#each upgrades}}{{{depName}}} {{{newVersion}}}{{#unless @last}}, {{/unless}}{{/each}})",
      "automerge": false
    }
  ]
}
