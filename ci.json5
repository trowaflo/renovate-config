{
  packageRules: [
    {
      // GitHub Actions Updates - all types grouped in a single PR
      matchManagers: ['github-actions'],
      groupName: 'GitHub Actions',
      separateMajorMinor: false,
      commitMessagePrefix: 'ci(github-actions){{#if isMajor}}!{{/if}}:',
      automerge: false
    }
  ]
}
