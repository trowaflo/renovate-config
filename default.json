{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "mergeConfidence:all-badges",
    "github>trowaflo/renovate-config:ansible.json5",
    "github>trowaflo/renovate-config:ci.json5",
    "github>trowaflo/renovate-config:docker.json5",
    "github>trowaflo/renovate-config:git-ops.json5",
    "github>trowaflo/renovate-config:helm.json5",
    "github>trowaflo/renovate-config:kubernetes.json5",
    "github>trowaflo/renovate-config:no_category.json5"
  ],
  "reviewers": ["trowaflo"],
  "minimumReleaseAge": "30 days",
  "minimumReleaseAgeBehavior": "timestamp-required",
  "internalChecksFilter": "strict",
  "commitBodyTable": true,
  "commitMessageExtra": "({{#each upgrades}}{{{depName}}} {{{newVersion}}}{{#unless @last}}, {{/unless}}{{/each}})",
  "pinDigests": true,
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["breaking"]
    }
  ],
  "timezone": "Europe/Paris",
  "schedule": [
    "before 5am on the first day of the month"
  ]
}
